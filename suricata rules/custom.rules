# Custom rules for your SOC lab
alert tcp any any -> any 80 (msg:"Suspicious HTTP Traffic - Possible Brute Force"; flow:to_server,established; content:"login"; nocase; sid:1000001; rev:1;)
alert tcp any any -> any 443 (msg:"Possible Phishing Attempt"; flow:to_server,established; content:"password"; nocase; sid:1000002; rev:1;)
